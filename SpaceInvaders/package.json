{
  "scripts": {
    "start": "parcel ./src/index.html",
    "build": "rm -rf build && parcel build -d build --public-url ./ --no-source-maps ./src/index.html",
    "zip": "rm -f bundle.zip && cd build && bestzip ../bundle.zip *",
    "bundle": "yarn build && yarn zip",
    "test": "jest"
  },
  "devDependencies": {
    "bestzip": "^2.2.0",
    "parcel-bundler": "^1.12.5",
    "sass": "^1.39.0",
    "typescript": "^4.4.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|js)$": "ts-jest"
    }
  },
  "name": "spaceinvaders",
  "version": "1.0.0",
  "description": "Simple game made for [js13k](https://js13kgames.com/) ![Gif showing the game](./screenshots/game.gif)",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
